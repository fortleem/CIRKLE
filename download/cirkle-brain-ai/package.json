{
  "name": "cirkle-brain-ai",
  "version": "14.0.0",
  "description": "CIRKLE Brain AI — 9-phase cognitive operating system (standalone)",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "train": "bun run scripts/train-brain.ts",
    "seed": "bun run scripts/seed-brain.ts",
    "news-service": "cd mini-services/news-service && bun run dev",
    "chat-service": "cd mini-services/chat-service && bun run dev",
    "ai-realtime": "cd mini-services/ai-realtime && bun run dev"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "next": "16.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.460.0",
    "zod": "^3.23.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.19.2",
    "typescript": "^5.6.0",
    "eslint": "^9.0.0",
    "bun-types": "latest"
  }
}
