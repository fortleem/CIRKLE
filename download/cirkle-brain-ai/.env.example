# ── CIRKLE Brain AI — Environment Configuration ──────────────────────────────
# Copy this file to .env and fill in your 5 AI provider keys.
# All keys have free tiers. The Brain works with any subset of providers
# (it falls back gracefully if a provider is unavailable).

# ── 5 AI Providers (ZAI removed) ─────────────────────────────────────────────

# Groq — fastest provider, great for Arabic
# Free tier: https://console.groq.com
# Model: llama-3.3-70b-versatile
GROQ_API_KEY=

# OpenRouter — web-search-enabled provider (replaces ZAI web_search)
# Free tier: https://openrouter.ai
# Model: openrouter/auto:online (the :online suffix enables live web search)
OPENROUTER_API_KEY=

# Gemini — vision, reasoning, cultural context, Google Search grounding
# Free tier: https://aistudio.google.com
# Models: gemini-1.5-flash, gemini-2.0-flash-exp
GEMINI_API_KEY=

# OpenAI — strong reasoning, code generation
# Paid: https://platform.openai.com
# Model: gpt-4o-mini
OPENAI_API_KEY=

# HuggingFace — free tier, Mistral-7B
# Free tier: https://huggingface.co/settings/tokens
# Model: mistralai/Mistral-7B-Instruct-v0.3
HUGGINGFACE_API_KEY=

# ── Database (SQLite — zero config) ───────────────────────────────────────────
# Default: local SQLite file. Change to PostgreSQL for production.
DATABASE_URL="file:./db/cirkle-brain.db"

# ── Optional: Mini-services ──────────────────────────────────────────────────
# The mini-services (chat, news, ai-realtime) run on separate ports.
# They are optional — the Brain works without them.
# CHAT_SERVICE_PORT=3003
# NEWS_SERVICE_PORT=3004
# AI_REALTIME_PORT=3001

# ── Optional: Production ─────────────────────────────────────────────────────
# NODE_ENV=production
# VERCEL=1
